.vscode/
.idea/
*.swp

# ============================================================
# OS
# ============================================================
.DS_Store
Thumbs.db
bot.log
bit.log

# ============================================================
# ORIGINAL AUDIO POOL (Moved to bottom so it overrides global *.mp3 / *.wav ignores)
# ============================================================
# Original_audio pool: ignore everything EXCEPT the pool files that must persist across CI runs.
# The audio pool (active/ + cooldown/ + beats/ + pool_metadata.json) must survive across
# GitHub Actions runner sessions — otherwise the pool is always empty and rotation never works.
Original_audio/**
!Original_audio/active/
!Original_audio/active/*.mp3
!Original_audio/active/*.wav
!Original_audio/cooldown/
!Original_audio/cooldown/*.mp3
!Original_audio/cooldown/*.wav
!Original_audio/beats/
!Original_audio/beats/*.npz
!Original_audio/pool_metadata.json

# ============================================================
# EXCLUDED MODULES
# ============================================================
Telegram_Video_Uploader/
ceie/output/
Compilations/viral_vanguard_*.json

# Runtime temp files
last_failed_reconstruction.txt
processed_video_feature_report.json


