# ─────────────────────────────────────────────────────────────────────────────
# REFINEMENT PROMPT v2.0
# Fired when attempt 1 scores < MID_CONFIDENCE (0.65).
# Specifically targets the three most common failure modes:
#   1. Weak wear_name (colour-first or generic)
#   2. Wrong or uncertain fabric identification
#   3. Vague sub_category
# ─────────────────────────────────────────────────────────────────────────────
 
REFINEMENT_PROMPT = """
YOUR PREVIOUS ANALYSIS WAS REJECTED. CONFIDENCE TOO LOW.
 
HERE IS WHAT YOU GOT WRONG AND EXACTLY HOW TO FIX IT:
 
PREVIOUS OUTPUT:
{previous_output}
 
════════════════════════════════════════════════════════════════
FAILURE MODE DIAGNOSIS — READ EVERY POINT
════════════════════════════════════════════════════════════════
 
FAILURE 1 — WEAK wear_name (THE MOST COMMON ERROR):
  Your wear_name was probably colour-first or too generic.
  A wear_name like "Red Metallic Dress" or "Sequin Outfit" is WORTHLESS.
  Nobody searches for it on Myntra. Nobody clicks it on Amazon.
 
  The CORRECT wear_name formula is:
  [Key Structural Feature] + [Neckline/Sleeve Detail] + [Fabric] + [Silhouette] + [Category]
 
  Re-examine the garment RIGHT NOW and ask:
    → What is the FIRST THING a stylist would say about this garment?
      (Usually: the neckline OR the most distinctive construction detail)
    → What FABRIC does this look like based on how light hits it?
    → What SILHOUETTE is this? (A-line? Bodycon? Flared? Column?)
    → What is the PRECISE sub-category? (not "dress" — "slip midi dress" / "tiered maxi dress")
 
  Produce a new wear_name that passes this test:
  "Could a buyer on Myntra search for EXACTLY these words and find THIS item?"
  If yes → it's correct. If no → too generic, try again.
 
FAILURE 2 — WRONG OR UNCERTAIN FABRIC:
  If your primary_material was "polyester" or "rayon", that means you
  gave up on fabric identification too quickly. These are FALLBACK LABELS.
  Try again using the visual forensics techniques:
 
  → HIGHLIGHT ANALYSIS: Is the highlight sharp (satin) or diffuse (crepe/georgette)?
  → DRAPE WAVE: Does the fabric fold in soft S-curves (silk/georgette) or angular (cotton)?
  → SHADOW EDGE: Does the hem hold its shape (structured) or collapse (fluid)?
  → TEXTURE GRAIN: Can you see any surface texture — ribs, weave, pile, shimmer?
 
  What does the fabric do when the body moves? (Refer to all frames, not just one)
 
FAILURE 3 — VAGUE sub_category:
  If sub_category was "dress" / "outfit" / "party wear" / "ethnic dress" → WRONG.
  The sub_category must be the FULL STRUCTURAL DESCRIPTION.
  Minimum 4 words. Ideally 6–8 words.
  Formula: [neckline] + [sleeve] + [fabric] + [silhouette] + [category]
 
FAILURE 4 — GENERIC search_query:
  If your query was under 6 words or contained banned adjectives → WRONG.
  The query must start with COLOUR, contain FABRIC, contain SUB-CATEGORY, end with OCCASION.
 
════════════════════════════════════════════════════════════════
YOUR TASK: PRODUCE AN IMPROVED ANALYSIS
════════════════════════════════════════════════════════════════
1. RE-RUN Phase 0 (Multimodal Exploitation) — use ALL 7 visual forensics techniques.
   Do not skip any technique. Each one catches something the previous attempt missed.
 
2. RE-CONFIRM the dominant garment (Phase 1) — make sure you're still analysing the right one.
 
3. RE-DO Fabric Fingerprinting (Phase 2) — use highlight, shadow, drape, and texture analysis.
   If you still cannot determine fabric exactly, name your top TWO candidates and
   choose the one that best matches the visual evidence. Never default to polyester.
 
4. RE-DO the Retail Product Naming Engine (Phase 6):
   → write the new wear_name LAST, after you've confirmed fabric and silhouette
   → verify it against the formula: not colour-first, not banned adjectives, 5-10 words
   → self-check: "Does this wear_name appear in Myntra's search results category?"
 
5. IMPROVE SPECIFICITY in at least FOUR attribute fields compared to previous output.
 
6. The overall confidence score MUST be strictly higher than {previous_confidence:.2f}.
   If you cannot improve confidence, explain WHY in the fabric.structure field.
 
════════════════════════════════════════════════════════════════
STRICT RULES
════════════════════════════════════════════════════════════════
• DO NOT repeat or copy any field from the previous output verbatim
• Return STRICT JSON ONLY — no markdown, no commentary, no preamble
• The wear_name field is now worth 20% of your output quality score — treat it as the headline
 
RETURN THE IMPROVED JSON NOW.
"""


# ─────────────────────────────────────────────────────────────────────────────
# AFFILIATE LINK UTILITIES
# ─────────────────────────────────────────────────────────────────────────────

def _fuzzy_match_product(
    item_name: str,
    category_data: Dict[str, str],
    threshold: float = 0.45,
) -> Optional[str]:
    """
    Jaccard word-overlap matcher for product keys within a category bucket.

    Compares item_name against every stored product-name key and returns the
    affiliate link whose key scores highest — provided the score meets threshold.

    Example
    -------
    Stored key : "brown sleeveless dress"
    Query      : "Sleeveless Brown Mini Dress"
    Overlap    : {brown, sleeveless, dress} / {brown, sleeveless, mini, dress} = 0.75 ✅
    """
    if not item_name or not category_data:
        return None

    query_words: set = set(item_name.lower().split())
    best_score  = 0.0
    best_link: Optional[str] = None

    for stored_key, link in category_data.items():
        stored_words: set = set(stored_key.lower().split())
        union = query_words | stored_words
        if not union:
            continue
        score = len(query_words & stored_words) / len(union)
        if score > best_score:
            best_score = score
            best_link  = link

    if best_score >= threshold:
        logger.debug(
            "[AFF_MATCH] '%s' → score=%.2f ≥ %.2f → link found",
            item_name, best_score, threshold,
        )
        return best_link

    logger.debug(
        "[AFF_MATCH] '%s' → best score=%.2f < %.2f → no match",
        item_name, best_score, threshold,
    )
    return None


def _get_affiliate_link(item_category: str, item_name: str = "") -> Optional[str]:
    """
    Returns the most specific Amazon affiliate link for the detected product.

    Lookup priority (returns None if nothing matches — no generic fallback):
      1. category bucket → fuzzy item_name match  (most specific — product link)
      2. category bucket → single-entry shortcut  (only one link saved for that category)
    """
    if not item_category:
        return None

    try:
        if not os.path.exists(_AFFILIATE_FILE):
            return None

        with open(_AFFILIATE_FILE, "r", encoding="utf-8") as fh:
            data: Dict = json.load(fh)

        # Case-insensitive category key resolution
        cat_lower = item_category.lower().strip()
        cat_key: Optional[str] = next(
            (k for k in data if k.lower() == cat_lower
             or k.lower() in cat_lower
             or cat_lower in k.lower()),
            None,
        )

        if not cat_key:
            return None

        cat_data = data[cat_key]

        # ── Nested format: {category: {item_name: link}} ──────────────────────
        if isinstance(cat_data, dict):
            if not cat_data:
                return None
            return _fuzzy_match_product(item_name or item_category, cat_data)

        # ── Legacy flat formats (backward-compat) ─────────────────────────────
        if isinstance(cat_data, list) and cat_data:
            return cat_data[0]
        if isinstance(cat_data, str):
            return cat_data

    except Exception as exc:
        logger.warning("[FASHION_SCOUT] Affiliate link lookup failed: %s", exc)

    return None


def save_affiliate_link(
    item_category: str,
    item_name: str,
    link: str,
    video_uid: Optional[str] = None,
) -> bool:
    """
    Persists a user-provided affiliate link using a dual-key strategy.

      1. by_uid[video_uid]   — exact UID lookup (DM bot — no fuzzy matching needed)
      2. [category][item_name] — legacy fuzzy-match bucket (AI DM fallback)

    video_uid is optional; when absent only the category bucket is written.

    Returns True on success, False on any write failure.
    """
    try:
        data: Dict = {}
        if os.path.exists(_AFFILIATE_FILE):
            with open(_AFFILIATE_FILE, "r", encoding="utf-8") as fh:
                try:
                    data = json.load(fh)
                except json.JSONDecodeError:
                    logger.warning("[FASHION_SCOUT] Corrupt affiliate JSON — starting fresh.")

        # ── 1. Exact UID path ─────────────────────────────────────────────────
        if video_uid:
            by_uid: Dict = data.setdefault("by_uid", {})
            by_uid[video_uid] = {
                "link":      link,
                "item_name": item_name.strip() if item_name else "",
                "category":  item_category.lower().strip() if item_category else "default",
                "saved_at":  datetime.utcnow().isoformat(),
            }
            logger.info("[FASHION_SCOUT] UID link saved: [%s] → %s", video_uid, link)

        # ── 2. Category / item-name bucket ────────────────────────────────────
        cat_key  = item_category.lower().strip() if item_category else "default"
        item_key = item_name.strip() if item_name else cat_key

        if cat_key not in data:
            data[cat_key] = {}

        # Migrate legacy flat schema if needed
        if not isinstance(data[cat_key], dict):
            legacy = data[cat_key]
            data[cat_key] = {}
            if isinstance(legacy, list) and legacy:
                data[cat_key]["default"] = legacy[0]
            elif isinstance(legacy, str):
                data[cat_key]["default"] = legacy

        data[cat_key][item_key] = link

        os.makedirs(os.path.dirname(_AFFILIATE_FILE), exist_ok=True)
        with open(_AFFILIATE_FILE, "w", encoding="utf-8") as fh:
            json.dump(data, fh, indent=4, ensure_ascii=False)

        logger.info(
            "[FASHION_SCOUT] Saved affiliate link: [%s] '%s' → %s",
            cat_key, item_key, link,
        )
        return True

    except Exception as exc:
        logger.error("[FASHION_SCOUT] Failed to save affiliate link: %s", exc)
        return False


# ─────────────────────────────────────────────────────────────────────────────
# OUTPUT VALIDATION
# ─────────────────────────────────────────────────────────────────────────────

def validate_output(data: Dict) -> bool:
    """
    Hard schema-validation gate. Rejects any result that would produce a bad
    Amazon search or is structurally incomplete.

    Called inside the retry loop — failed results are discarded, not used.
    """
    if not isinstance(data, dict):
        return False

    # ── Visual Dominance block ────────────────────────────────────────────────
    vd = data.get("visual_dominance", {})
    if not isinstance(vd, dict) or not vd.get("primary_garment_id", "").strip():
        logger.debug("[VALIDATE] Rejected: visual_dominance block missing or primary_garment_id empty")
        return False

    if vd.get("dominance_score", 0) < 3:
        logger.debug("[VALIDATE] Rejected: dominance_score < 3 — garment not clearly identified")
        return False

    # ── search_query: at least 4 real words ──────────────────────────────────
    query = data.get("search_query", "").strip()
    if not query or len(query.split()) < 4:
        logger.debug("[VALIDATE] Rejected: search_query too short or missing")
        return False

    # ── seo_keywords: at least 5 entries ─────────────────────────────────────
    if len(data.get("seo_keywords", [])) < 5:
        logger.debug("[VALIDATE] Rejected: seo_keywords < 5")
        return False

    # ── attributes block with classification ─────────────────────────────────
    attrs = data.get("attributes", {})
    if not isinstance(attrs, dict) or not attrs:
        logger.debug("[VALIDATE] Rejected: attributes block missing")
        return False

    classification = attrs.get("classification", {})
    if not isinstance(classification, dict) or not classification.get("primary_category"):
        logger.debug("[VALIDATE] Rejected: primary_category empty")
        return False

    # ── outfit_description ───────────────────────────────────────────────────
    if not data.get("outfit_description", "").strip():
        logger.debug("[VALIDATE] Rejected: outfit_description missing")
        return False

    # ── wear_name quality gate ───────────────────────────────────────────────
    # Threshold raised from 0.40 → 0.55 so colour-first/generic names ("Black Dress",
    # "Dark Satin Gown") fail validation and trigger the refinement retry loop
    # instead of silently passing through as the final output.
    wear_name = data.get("wear_name", "")
    if wear_name and score_wear_name_quality(wear_name) < 0.55:
        logger.debug(
            "[VALIDATE] Rejected: wear_name '%s' quality score %.2f < 0.55 (needs industry-standard name)",
            wear_name, score_wear_name_quality(wear_name)
        )
        return False

    return True


# ─────────────────────────────────────────────────────────────────────────────
# QUERY QUALITY SCORER  (local, deterministic — does NOT trust Gemini's score)
# ─────────────────────────────────────────────────────────────────────────────

def score_query_quality(query: str) -> float:
    """
    Independent query quality scorer. Returns 0.0–1.0.

    Scoring breakdown (each component worth 0.20):
      • Word count in Amazon sweet spot (5–10 words)
      • Contains a recognised category keyword
      • Contains a recognised colour keyword
      • Contains a recognised fabric/material keyword
      • Contains NO banned vague adjectives
    """
    if not query or not query.strip():
        return 0.0

    words = query.lower().split()
    score = 0.0

    # Word count
    if 5 <= len(words) <= 10:
        score += 0.20
    elif 4 <= len(words) <= 12:   # acceptable but not ideal
        score += 0.10

    if any(w in _CATEGORY_KEYWORDS for w in words):
        score += 0.20

    if any(w in _COLOR_KEYWORDS for w in words):
        score += 0.20

    if any(w in _FABRIC_KEYWORDS for w in words):
        score += 0.20

    if not any(w in _BANNED_ADJECTIVES for w in words):
        score += 0.20

    return round(score, 2)


# ─────────────────────────────────────────────────────────────────────────────
# WEAR NAME QUALITY SCORER
# ─────────────────────────────────────────────────────────────────────────────

# ── Extended colour-adjacent adjectives that signal a colour-first name ─────
_COLOUR_ADJECTIVES: frozenset = frozenset({
    "dark", "deep", "light", "pale", "dusty", "muted", "bright", "neon",
    "pastel", "rich", "soft", "bold", "warm", "cool", "neutral", "pure",
})

# ── Structural specificity keywords that signal a retail-grade name ──────────
# These are neckline, silhouette, construction, and feature words that
# appear in Myntra/ASOS product titles but NOT in generic descriptions.
_STRUCTURAL_KEYWORDS: frozenset = frozenset({
    # Necklines
    "v-neck", "deep-v", "cowl", "halter", "sweetheart", "scoop", "turtleneck",
    "mock-neck", "boat", "off-shoulder", "one-shoulder", "bandeau", "asymmetric",
    "square", "crewneck",
    # Silhouettes
    "bodycon", "a-line", "flared", "mermaid", "column", "sheath", "tiered",
    "peplum", "ballgown", "high-low", "wrap", "fit-and-flare",
    # Sleeve/construction
    "puff", "balloon", "bishop", "cold-shoulder", "backless", "cut-out",
    "ruched", "shirred", "smocked", "boned", "corset", "panelled",
    "bias-cut", "draped", "pleated", "ruffle", "frill",
    # Ethnic structural
    "anarkali", "lehenga", "sharara", "gharara", "kurta", "palazzo",
    "dupatta", "kanjivaram", "banarasi", "chanderi", "bandhani", "zari",
    # Length modifiers
    "midi", "maxi", "mini", "micro", "floor", "cropped",
    # Feature words that signal specificity
    "sequin", "embroidered", "embellished", "mirror", "gota", "resham",
    "lace", "feather", "fringe", "laser-cut", "3d", "applique",
})


def score_wear_name_quality(wear_name: str) -> float:
    """
    Evaluates product title (wear_name) for retail-grade (industry-standard) naming.
    Returns 0.0-1.0.

    Scoring breakdown:
      +0.25  → Word count 5–10 (matching the prompt spec)
      +0.25  → Does NOT start with a colour/colour-adjective (feature-first)
      +0.20  → Contains a garment category keyword
      +0.20  → Contains a fabric keyword
      +0.10  → Contains at least one structural specificity keyword
      -0.60  → Uses any banned adjective (stylish/trendy/etc.)
      -0.20  → Starts with a colour adjective (dark/deep/light/etc.)
    """
    if not wear_name or not wear_name.strip():
        return 0.0

    words = wear_name.lower().split()
    score = 0.0

    # ── Length: 5–10 words is the retail sweet spot (matches prompt spec) ────
    if 5 <= len(words) <= 10:
        score += 0.25
    elif 4 <= len(words) <= 12:      # borderline acceptable
        score += 0.10
    # ≤3 words: no length bonus ("Black Satin Dress" = 0)

    # ── Colour-first penalty: word[0] is a colour OR a colour adjective ──────
    first_word = words[0] if words else ""
    is_colour_first = (
        first_word in _COLOR_KEYWORDS
        or first_word in _COLOUR_ADJECTIVES
        or (len(words) >= 2 and first_word in _COLOUR_ADJECTIVES and words[1] in _COLOR_KEYWORDS)
    )
    if not is_colour_first:
        score += 0.25
    else:
        score -= 0.20   # active penalty: colour-first names are retail failures

    # ── Must contain a garment category keyword ───────────────────────────────
    if any(w in _CATEGORY_KEYWORDS for w in words):
        score += 0.20

    # ── Must contain a fabric keyword ─────────────────────────────────────────
    if any(w in _FABRIC_KEYWORDS for w in words):
        score += 0.20

    # ── Structural specificity bonus ─────────────────────────────────────────
    # Industry names have neckline / silhouette / construction words.
    # "Cowl Neck Ruched Satin Slip Midi Dress" passes. "Black Dress" does not.
    if any(w in _STRUCTURAL_KEYWORDS for w in words):
        score += 0.10

    # ── Banned adjective hard penalty ────────────────────────────────────────
    if any(w in _BANNED_ADJECTIVES for w in words):
        score -= 0.60

    return max(0.0, min(1.0, round(score, 3)))


# ─────────────────────────────────────────────────────────────────────────────
# FASHION SCOUT CLASS
# ─────────────────────────────────────────────────────────────────────────────

class FashionScout:
    """
    Hierarchical Fashion Intelligence Pipeline.

    Public API
    ----------
    scout_outfit(image_paths, visual_hint) → Dict | None
    """

    def __init__(self) -> None:
        self.font_path: str = os.path.abspath("assets/fonts/Inter-Bold.ttf")
        # Stores the best result from the most recent scout_outfit call
        # (used for analytics, learning loops, and upstream caching)
        self.last_best_result: Optional[Dict] = None

    # ─────────────────────────────────────────────────────────────────────────
    # INTERNAL: Gemini vision call
    # ─────────────────────────────────────────────────────────────────────────

    def _run_analysis(
        self,
        image_paths: List[str],
        prompt_override: Optional[str] = None,
        visual_hint: Optional[Dict] = None,
    ) -> Optional[Dict]:
        """
        Sends image frames + prompt to Gemini Vision and returns a parsed JSON dict.

        Parameters
        ----------
        image_paths     : Ordered list of frame file paths (up to 4 are sent).
        prompt_override : Replaces the default TREND_CONTEXT_PROMPT when provided
                          (used for refinement passes).
        visual_hint     : Pre-extracted structured context from monetization_brain.
                          When present, Gemini is GUIDED rather than running blind,
                          consistently lifting confidence from ~0.4 → ~0.7–0.9.
        """
        try:
            base_prompt = prompt_override if prompt_override else TREND_CONTEXT_PROMPT

            # ── Hierarchical Intelligence: inject visual_hint as authoritative preamble ──
            if visual_hint:
                _hint_instruction = visual_hint.pop("_instruction", None)
                if _hint_instruction:
                    # Guidance-only mode: hint provides background context but does NOT
                    # dictate garment type. Gemini must run all forensic phases independently.
                    hint_block = (
                        "BACKGROUND CONTEXT  [SUPPLEMENTARY — DO NOT LET THIS OVERRIDE YOUR VISUAL ANALYSIS]\n"
                        "────────────────────────────────────────────────────────────\n"
                        + json.dumps(visual_hint, indent=2)
                        + "\n\n"
                        "INSTRUCTIONS:\n"
                        "  • This context provides colour/occasion background ONLY\n"
                        "  • Do NOT use this to pre-determine the garment TYPE or STRUCTURE\n"
                        "  • Run ALL forensic phases (0-9) independently from this context\n"
                        "  • Your Phase 1 Visual Dominance Detection is the authoritative anchor\n"
                        "  • The wear_name MUST come from your own Phase 6 Retail Naming Engine\n"
                        "  • Specific structural details (corset boning, slit, maxi length, etc.)\n"
                        "    MUST come from your visual analysis — NOT from this hint\n\n"
                    )
                else:
                    # Authoritative mode: upstream provided high-quality structured data
                    hint_block = (
                        "KNOWN CONTEXT  [HIGH CONFIDENCE — FROM UPSTREAM ANALYSIS]\n"
                        "────────────────────────────────────────────────────────────\n"
                        + json.dumps(visual_hint, indent=2)
                        + "\n\n"
                        "INSTRUCTIONS FOR USING THIS CONTEXT:\n"
                        "  • Treat this as ground truth for the fields it covers\n"
                        "  • Only REFINE missing or low-specificity attributes\n"
                        "  • Do NOT override unless the image clearly contradicts it\n"
                        "  • Your confidence score MUST reflect this structured head-start\n"
                        "  • Still run Step 0 (Visual Dominance Detection) to confirm anchor garment\n\n"
                    )
                full_prompt = hint_block + base_prompt
                logger.info("[FASHION_SCOUT] visual_hint injected — %s mode active",
                            "guidance-only" if _hint_instruction else "authoritative")

            else:
                full_prompt = base_prompt

            # ── Step 5: Inject First Shot Library categories for intro selection ──
            try:
                _lib_path = os.path.join(os.path.dirname(os.path.dirname(__file__)), "First_Shots", "library_index.json")
                if os.path.exists(_lib_path):
                    with open(_lib_path, "r", encoding="utf-8") as _f:
                        _lib = json.load(_f)
                        _topics = []
                        for _k, _v in _lib.items():
                            if _k == "_meta": continue
                            _script = _v.get("script", "")
                            _desc = _v.get("description", "")
                            _topics.append(f"[{_k}] - Script: '{_script}' | Desc: '{_desc}'")
                        _topics_str = "\n".join(_topics)
                        
                        _lib_info = (
                            f"\nSTEP 5 — FIRST SHOT (INTRO) CATEGORY MATCHING\n"
                            f"Available Library Categories:\n{_topics_str}\n\n"
                            f"RULES:\n"
                            f"1. If the garment perfectly matches an existing category, set 'genre' to that exact category key.\n"
                            f"2. If it is a distinct, unlisted product, set 'genre' to 'NEW'.\n"
                            f"3. Set 'wear_name' using the strict retail naming formula: [Feature] + [Neckline] + [Fabric] + [Silhouette] + [Category]. Do not use color-first or generic names.\n\n"
                        )
                        # Insert before the JSON schema block for better adherence
                        if "OUTPUT — STRICT JSON ONLY" in full_prompt:
                            full_prompt = full_prompt.replace("OUTPUT — STRICT JSON ONLY", _lib_info + "OUTPUT — STRICT JSON ONLY")
                        else:
                            full_prompt += _lib_info
            except Exception as _e:
                logger.warning(f"[FASHION_SCOUT] Failed to inject library_index.json: {_e}")

            # ── Assemble vision parts: [prompt_text, frame_0, frame_1, ...] ──
            vision_parts: List = [full_prompt]
            for img_path in image_paths[:4]:
                try:
                    vision_parts.append(Image.open(img_path).convert("RGB"))
                except Exception as exc:
                    logger.warning("[FASHION_SCOUT] Frame load failed (%s): %s", img_path, exc)

            if len(vision_parts) == 1:
                # No valid frames loaded — cannot proceed
                logger.warning("[FASHION_SCOUT] No valid frames loaded — skipping Gemini call.")
                return None

            # ── Gemini call via router ────────────────────────────────────────
            res_txt: Optional[str] = gemini_router.generate(
                task_type="vision",
                prompt=vision_parts,
                module_name="fashion_scout_metrics",
                gen_config={
                    "temperature": 0.4,
                    "response_mime_type": "application/json",
                },
            )

            if not res_txt:
                logger.warning("[FASHION_SCOUT] Gemini returned empty response.")
                return None

            # ── Extract JSON from response (handles markdown code fences too) ──
            match = re.search(r'(\{.*\})', res_txt, re.DOTALL)
            if not match:
                logger.warning("[FASHION_SCOUT] No JSON object found in Gemini response.")
                return None

            parsed: Dict = json.loads(match.group(1))

            # ── Hard validation: attributes block must exist and be non-empty ──
            if not parsed.get("attributes"):
                raise ValueError(
                    "[FASHION_SCOUT] Hard validation failed: "
                    "'attributes' block missing or empty in Gemini response."
                )

            # ── Hard validation: visual_dominance block must name a garment ──
            vd = parsed.get("visual_dominance", {})
            if not isinstance(vd, dict) or not vd.get("primary_garment_id", "").strip():
                raise ValueError(
                    "[FASHION_SCOUT] Hard validation failed: "
                    "'visual_dominance.primary_garment_id' missing — Step 0 was not executed."
                )

            return parsed

        except ValueError as ve:
            logger.error("%s", ve)
            return None
        except json.JSONDecodeError as je:
            logger.error("[FASHION_SCOUT] JSON parse failed: %s", je)
            return None
        except Exception as exc:
            logger.error("[FASHION_SCOUT] _run_analysis unexpected error: %s", exc)
            return None

    # ─────────────────────────────────────────────────────────────────────────
    # INTERNAL: Attribute enforcement (Python-layer — cannot be hallucinated)
    # ─────────────────────────────────────────────────────────────────────────

    def _enforce_attributes(self, data: Dict) -> Dict:
        """
        Guarantees no critical attribute field is blank after Gemini's response.

        Inference chain (Python logic only — no LLM involved):
          • primary_category ← sub_category word[0]
          • primary_category ← visual_dominance.primary_garment_id  (NEW v2.0)
          • gender_target    ← "women"  (safe default for Indian fashion content)
          • age_group        ← "young-adult"
          • occasion         ← inferred from brand_dna.market signal
          • color.primary    ← color.tone  (fallback shade)
          • fit.fit_type     ← fit.silhouette  (fallback fit label)
        """
        attrs = data.setdefault("attributes", {})
        cls   = attrs.setdefault("classification", {})
        color = attrs.get("color", {})   if isinstance(attrs.get("color"),     dict) else {}
        fit   = attrs.get("fit",   {})   if isinstance(attrs.get("fit"),       dict) else {}
        brand = attrs.get("brand_dna", {}) if isinstance(attrs.get("brand_dna"), dict) else {}

        # primary_category — try sub_category, then visual_dominance garment name
        if not cls.get("primary_category"):
            sub = cls.get("sub_category", "")
            if sub:
                cls["primary_category"] = sub.split()[0].lower()
                logger.debug(
                    "[ENFORCE] primary_category inferred from sub_category: '%s'",
                    cls["primary_category"],
                )
            else:
                # NEW v2.0: fall back to visual_dominance anchor garment
                vd_garment = (
                    data.get("visual_dominance", {})
                        .get("primary_garment_id", "")
                        .lower()
                        .strip()
                )
                if vd_garment:
                    # Take the last word (e.g. "cobalt silk saree" → "saree")
                    cls["primary_category"] = vd_garment.split()[-1]
                    logger.debug(
                        "[ENFORCE] primary_category inferred from visual_dominance: '%s'",
                        cls["primary_category"],
                    )

        if not cls.get("gender_target"):
            cls["gender_target"] = "women"

        if not cls.get("age_group"):
            cls["age_group"] = "young-adult"

        if not cls.get("occasion"):
            market = brand.get("market", "").lower()
            if any(k in market for k in ("athleisure", "sports")):
                cls["occasion"] = "gym"
            elif "fast-fashion" in market:
                cls["occasion"] = "casual"
            elif any(k in market for k in ("luxury", "designer")):
                cls["occasion"] = "party"
            else:
                cls["occasion"] = "casual"

        if isinstance(color, dict) and not color.get("primary"):
            tone = color.get("tone", "")
            if tone:
                color["primary"] = tone

        if isinstance(fit, dict) and not fit.get("fit_type"):
            silhouette = fit.get("silhouette", "")
            if silhouette:
                fit["fit_type"] = silhouette.lower()

        return data

    # ─────────────────────────────────────────────────────────────────────────
    # INTERNAL: Local deterministic query builder
    # ─────────────────────────────────────────────────────────────────────────

    def build_query_from_attributes(self, data: Dict) -> str:
        """
        Deterministic Amazon query builder — pure Python, zero hallucination risk.

        Formula: [Color] [Fabric] [Fit] [SubCategory|Category] [Occasion] [Gender]

        This is Tier-1 in the 3-tier query priority system and fires when its
        score_query_quality result ≥ 0.60.

        v2.0: Prioritises the visual_dominance.primary_garment_id as the category
        anchor when classification.sub_category is absent.
        """
        attrs = data.get("attributes", {})
        color = attrs.get("color",    {}) if isinstance(attrs.get("color"),    dict) else {}
        fabric= attrs.get("fabric",   {}) if isinstance(attrs.get("fabric"),   dict) else {}
        fit   = attrs.get("fit",      {}) if isinstance(attrs.get("fit"),      dict) else {}
        cls   = attrs.get("classification", {}) if isinstance(attrs.get("classification"), dict) else {}

        primary_color  = color.get("primary", "")
        primary_fabric = fabric.get("primary_material", "")
        fit_type       = fit.get("fit_type", "")
        sub_cat        = cls.get("sub_category", "")
        category       = cls.get("primary_category", "")
        occasion       = cls.get("occasion", "")
        gender         = cls.get("gender_target", "women")

        # v2.0: If still no item term, pull from visual_dominance anchor garment
        vd_garment = (
            data.get("visual_dominance", {})
                .get("primary_garment_id", "")
                .strip()
        )
        item_term = sub_cat or category or vd_garment.split()[-1] if vd_garment else ""

        parts = [
            p.strip() for p in
            [primary_color, primary_fabric, fit_type, item_term, occasion, gender]
            if p and p.strip()
        ]

        # Cap at 8 words for Amazon sweet spot
        built = " ".join(parts[:8])
        logger.info("[FASHION_SCOUT] Deterministic query built: '%s'", built)
        return built

    # ─────────────────────────────────────────────────────────────────────────
    # PUBLIC: Main pipeline entry point
    # ─────────────────────────────────────────────────────────────────────────

    def scout_outfit(
        self,
        image_paths: List[str],
        visual_hint: Optional[Dict] = None,
    ) -> Optional[Dict]:
        """
        Hierarchical Fashion Intelligence Pipeline.

        Flow
        ----
        1. Up to MAX_RETRIES Gemini vision calls with combined scoring.
           Early-stop on HIGH_CONFIDENCE; immediate refinement if attempt 1 < MID_CONFIDENCE.
        2. Best-result selection by _internal_score.
        3. Attribute enforcement (Python layer — hallucination-proof).
        4. 3-tier query priority: local builder → Gemini → SEO keyword stitch.
        5. Affiliate link injection via fuzzy category/item matching.
        6. Money Flow CTA injection.
        7. Multi-garment schema normalisation.

        Parameters
        ----------
        image_paths : List of frame file paths to analyse.
        visual_hint : Optional pre-extracted context from monetization_brain.
                      Passed directly to Gemini as a high-confidence preamble,
                      lifting detection confidence consistently by ~0.3–0.5.

        Returns
        -------
        Enriched result dict on success, None on unrecoverable failure.
        """
        if not image_paths:
            logger.warning("[FASHION_SCOUT] scout_outfit called with empty image_paths.")
            return None

        # ── Lazy import of money_engine (handles both relative and absolute import paths) ──
        _money_engine = money_engine
        if _money_engine is None:
            try:
                from Intelligence_Modules.money_flow_logic import engine as _money_engine  # type: ignore
            except ImportError:
                logger.warning("[FASHION_SCOUT] money_flow_logic unavailable — CTAs will be skipped.")

        try:
            results: List[Dict] = []

            # ── RETRY LOOP ────────────────────────────────────────────────────
            for attempt in range(MAX_RETRIES):
                if attempt == 0:
                    # First pass: primary prompt + visual_hint for guided analysis
                    result = self._run_analysis(image_paths, visual_hint=visual_hint)
                else:
                    # Refinement pass: instruct Gemini to beat the previous weak output
                    prev = results[-1] if results else {}
                    refine_prompt = REFINEMENT_PROMPT.replace(
                        "{previous_output}",
                        json.dumps(prev, indent=2, ensure_ascii=False),
                    ).replace(
                        "{previous_confidence:.2f}",
                        f"{prev.get('_internal_score', 0.0):.2f}"
                    )
                    result = self._run_analysis(
                        image_paths,
                        prompt_override=refine_prompt,
                        visual_hint=visual_hint,
                    )

                if not result:
                    logger.warning("[FASHION_SCOUT] Attempt %d returned no result.", attempt + 1)
                    continue

                # ── Schema validation ─────────────────────────────────────────
                if not validate_output(result):
                    logger.warning(
                        "[FASHION_SCOUT] Attempt %d failed schema validation → forcing retry.",
                        attempt + 1,
                    )
                    continue

                # ── Combined scoring (AI self-report + local quality scorer) ──
                ai_score    = result.get("confidence", {}).get("overall", 0.0)
                query_score = score_query_quality(result.get("search_query", ""))
                
                wear_name   = result.get("wear_name", "")
                if not wear_name:
                    cls = result.get("attributes", {}).get("classification", {})
                    wear_name = cls.get("sub_category") or cls.get("primary_category", "")
                wear_score  = score_wear_name_quality(wear_name)
                
                # AI score weighted 50 % (semantic) + query 25 % + wear_name 25 %
                final_score = round((ai_score * 0.50) + (query_score * 0.25) + (wear_score * 0.25), 3)
                
                # Confidence penalty for generic/poor naming
                if wear_score < 0.50:
                    logger.warning("[FASHION_SCOUT] wear_name '%s' quality too low (%.2f) — applying confidence penalty", wear_name, wear_score)
                    final_score = max(0.0, final_score - 0.15)

                result["_internal_score"] = final_score
                logger.info(
                    "[FASHION_SCOUT] Attempt %d → ai=%.2f | query=%.2f | wear=%.2f | final=%.3f | "
                    "anchor='%s' | hint=%s",
                    attempt + 1,
                    ai_score,
                    query_score,
                    wear_score,
                    final_score,
                    result.get("visual_dominance", {}).get("primary_garment_id", "?"),
                    "YES" if visual_hint else "NO",
                )

                results.append(result)

                # ── Early-stop on high confidence ─────────────────────────────
                if final_score >= HIGH_CONFIDENCE:
                    logger.info(
                        "[FASHION_SCOUT] High confidence (%.3f) achieved → stopping retries.",
                        final_score,
                    )
                    break

                # ── Immediate refinement trigger on very low attempt-1 score ──
                if attempt == 0 and final_score < MID_CONFIDENCE:
                    logger.warning(
                        "[FASHION_SCOUT] Attempt 1 score %.3f < %.2f → triggering refinement immediately.",
                        final_score, MID_CONFIDENCE,
                    )
                    continue   # jumps to attempt 1 (refinement path)

                # ── Acceptable confidence — no need to continue ───────────────
                if final_score >= MID_CONFIDENCE:
                    logger.info(
                        "[FASHION_SCOUT] Acceptable confidence (%.3f) → stopping.",
                        final_score,
                    )
                    break

            # ── No valid result across all attempts ───────────────────────────
            if not results:
                logger.error("[FASHION_SCOUT] All %d attempts failed.", MAX_RETRIES)
                return None

            # ── Select best result ────────────────────────────────────────────
            data: Dict = max(results, key=lambda x: x.get("_internal_score", 0.0))
            self.last_best_result = data   # persist for analytics / learning loops

            # ── Warn if output is still low-confidence after all retries ──────
            if data.get("confidence", {}).get("overall", 0.0) < MID_CONFIDENCE:
                logger.warning(
                    "⚠️  Low-confidence detection persists after all retries "
                    "(overall=%.2f) — output may be imprecise.",
                    data["confidence"]["overall"],
                )

            # ── Attribute enforcement (Python-layer — hallucination-proof) ────
            data = self._enforce_attributes(data)

            # ── Affiliate link injection ──────────────────────────────────────
            classification = data.get("attributes", {}).get("classification", {})
            item_category  = (
                classification.get("primary_category")
                or classification.get("sub_category")
                or ""
            )
            # sub_category is the most descriptive term for fuzzy matching
            item_name_for_aff = (
                classification.get("sub_category")
                or data.get("search_query", "")
                or item_category
            )

            affiliate_link = _get_affiliate_link(item_category, item_name=item_name_for_aff)
            if affiliate_link:
                data["affiliate_link"] = affiliate_link
                logger.info(
                    "[FASHION_SCOUT] Affiliate link matched → category='%s' | item='%s'",
                    item_category, item_name_for_aff,
                )

            # [HIERARCHICAL_SYNC] Inject category for downstream SEO and display logic
            data["item_category"] = item_category

            # ── FINAL WEAR_NAME ENFORCEMENT ──────────────────────────────────
            # Even after retries, Gemini occasionally returns a colour-first or
            # generic wear_name ("Dark Satin Dress", "Black Top", "White Outfit").
            # If the best result's wear_name still scores < 0.55, rebuild it from
            # the structured attributes Gemini DID return correctly so the video
            # overlay shows a real industry-standard product label.
            _final_wear = data.get("wear_name", "")
            if score_wear_name_quality(_final_wear) < 0.55:
                attrs_f = data.get("attributes", {})
                fit_f   = attrs_f.get("fit", {})   if isinstance(attrs_f.get("fit"), dict) else {}
                fab_f   = attrs_f.get("fabric", {}) if isinstance(attrs_f.get("fabric"), dict) else {}
                cls_f   = attrs_f.get("classification", {}) if isinstance(attrs_f.get("classification"), dict) else {}
                pat_f   = attrs_f.get("pattern", {}) if isinstance(attrs_f.get("pattern"), dict) else {}

                _neckline   = fit_f.get("neckline", "")
                _sleeve     = fit_f.get("sleeve_type", "")
                _fabric     = fab_f.get("primary_material", "")
                _silhouette = fit_f.get("silhouette", "")
                _length     = fit_f.get("length", "")
                _category   = cls_f.get("primary_category", "") or item_category or ""
                _sub_cat    = cls_f.get("sub_category", "")
                _embellish  = pat_f.get("embellishment", "")
                _constr     = fit_f.get("construction_notes", "")

                # Use sub_category directly if it's specific enough
                if _sub_cat and len(_sub_cat.split()) >= 5:
                    _rebuilt = _sub_cat.strip().title()
                else:
                    # Build from atoms: [Embellish/Neckline] + [Sleeve] + [Fabric] + [Silhouette/Length] + [Category]
                    _atoms = []
                    # Feature/construction first (non-colour)
                    _feature = (
                        _embellish if _embellish and _embellish.lower() != "none" else
                        _constr.split(".")[0] if _constr else ""
                    )
                    if _feature and len(_feature) < 30:
                        _atoms.append(_feature.strip().title())
                    # Neckline
                    if _neckline and _neckline.lower() not in ("", "none", "crew"):
                        _atoms.append(_neckline.strip().title())
                    # Sleeve (skip if sleeveless for brevity, add if notable)
                    if _sleeve and _sleeve.lower() not in ("", "none", "sleeveless"):
                        _atoms.append(_sleeve.strip().title())
                    # Fabric
                    if _fabric and _fabric.lower() not in ("", "none", "polyester", "rayon"):
                        _atoms.append(_fabric.strip().title())
                    # Silhouette + length
                    if _silhouette and _silhouette.lower() not in ("", "none"):
                        _atoms.append(_silhouette.strip().title())
                    if _length and _length.lower() not in ("", "none"):
                        _atoms.append(_length.strip().title())
                    # Category last
                    if _category:
                        _atoms.append(_category.strip().title())

                    _rebuilt = " ".join(a for a in _atoms if a)[:80]  # max 80 chars

                if _rebuilt and len(_rebuilt.split()) >= 3:
                    logger.info(
                        "🔧 [WEAR_NAME_ENFORCE] Upgraded weak name '%s' → '%s'",
                        _final_wear, _rebuilt
                    )
                    data["wear_name"] = _rebuilt
                else:
                    logger.warning(
                        "⚠️ [WEAR_NAME_ENFORCE] Could not rebuild from attributes — keeping '%s'",
                        _final_wear
                    )
            # ─────────────────────────────────────────────────────────────────

            # ── BRAND ENRICHMENT PIPELINE ─────────────────────────────────────
            # When Gemini reads a brand logo (Nike, Adidas, Zara, etc.) with
            # confidence >= 0.7, we treat it as authoritative data and inject
            # it into wear_name and search_query for precise product discovery.
            _brand_info     = data.get("brand_detection", {}) or {}
            _detected_brand = (_brand_info.get("detected_brand") or "").strip()
            _brand_conf     = float(_brand_info.get("brand_confidence") or 0.0)
            _product_line   = (_brand_info.get("product_line") or "").strip()
            _logo_location  = (_brand_info.get("logo_location") or "").strip()

            # Expose as flat top-level fields so orchestrator / caption system
            # can consume them without digging into brand_detection dict.
            data["detected_brand"]   = _detected_brand
            data["brand_confidence"] = _brand_conf
            data["product_line"]     = _product_line

            if _detected_brand and _brand_conf >= 0.7:
                logger.info(
                    "👟 [BRAND_DETECT] High-confidence brand detected: '%s' "
                    "(conf=%.2f, line='%s', loc='%s')",
                    _detected_brand, _brand_conf, _product_line, _logo_location,
                )

                # ── 1. Upgrade wear_name to brand-first formula ────────────────
                _current_wear = data.get("wear_name", "")
                # Strip brand from wear_name if Gemini already started with it
                _wear_no_brand = _current_wear
                if _current_wear.lower().startswith(_detected_brand.lower()):
                    _wear_no_brand = _current_wear[len(_detected_brand):].strip()

                _brand_prefix = _detected_brand
                if _product_line:
                    _brand_prefix = f"{_detected_brand} {_product_line}"

                # Only prepend if not already present
                if _detected_brand.lower() not in _current_wear.lower():
                    data["wear_name"] = f"{_brand_prefix} {_wear_no_brand}".strip()
                    logger.info(
                        "🔧 [BRAND_INJECT] wear_name upgraded: '%s' → '%s'",
                        _current_wear, data["wear_name"],
                    )

                # ── 2. Build brand-first search query ─────────────────────────
                # Brand queries have 3x higher CTR on Amazon than generic queries.
                attrs_b = data.get("attributes", {})
                cls_b   = attrs_b.get("classification", {}) if isinstance(attrs_b.get("classification"), dict) else {}
                clr_b   = attrs_b.get("color", {}) if isinstance(attrs_b.get("color"), dict) else {}
                cat_b   = cls_b.get("primary_category", "") or item_category or ""
                sub_b   = cls_b.get("sub_category", "")
                clr_val = clr_b.get("primary", "")
                gender_b = cls_b.get("gender_target", "women")

                _brand_query_parts = [p for p in [
                    _brand_prefix,
                    clr_val if clr_val else "",
                    sub_b if sub_b else cat_b,
                    gender_b,
                ] if p]
                _brand_query = " ".join(_brand_query_parts)[:100]
                logger.info("🔍 [BRAND_QUERY] Brand-first query: '%s'", _brand_query)

                # Brand query overrides all three tiers — it's most specific
                data["brand_search_query"] = _brand_query

            elif _detected_brand and _brand_conf >= 0.5:
                logger.info(
                    "👟 [BRAND_DETECT] Medium-confidence brand: '%s' (conf=%.2f) "
                    "— mentioned in description but not injected into wear_name",
                    _detected_brand, _brand_conf,
                )
            # ─────────────────────────────────────────────────────────────────

            # ── Money Flow CTA injection ──────────────────────────────────────
            if _money_engine:
                try:
                    vibe  = data.get("vibe", "GLOBAL")
                    offer = _money_engine.get_optimized_offer(vibe)
                    data["imaginative_ctas"] = {
                        "english":    _money_engine.get_law_bending_cta(offer),
                        "hinglish":   f"{offer['hook']} (Complete Verification Step check karo)",
                        "roman_urdu": f"{offer['hook']} (Verification Step complete karein)",
                        "hindi":      f"{offer['hook']} (Industrial Verification पूरा करें)",
                    }
                    data["lead_magnet"] = offer["lead_magnet"]
                except Exception as cta_exc:
                    logger.warning("[FASHION_SCOUT] CTA injection failed: %s", cta_exc)

            # ── Multi-garment schema normalisation ────────────────────────────
            # Ensure primary_item / secondary_items keys always exist so
            # downstream consumers never need to guard for their absence.
            if "primary_item" not in data:
                data["primary_item"] = data.get("attributes", {})

            if "secondary_items" not in data:
                # Populate from visual_dominance.secondary_garments for richer data
                data["secondary_items"] = (
                    data.get("visual_dominance", {}).get("secondary_garments", [])
                )

            # ── 3-TIER QUERY PRIORITY ─────────────────────────────────────────
            # Tier 0 — brand-first query        (brand_conf ≥ 0.7)   ← BEST
            # Tier 1 — local deterministic      (score ≥ 0.60)       ← preferred
            # Tier 2 — Gemini's search_query    (score ≥ 0.40)       ← acceptable
            # Tier 3 — SEO keyword stitch        (fallback)           ← last resort
            if _detected_brand and _brand_conf >= 0.7 and data.get("brand_search_query"):
                final_query = data["brand_search_query"]
                logger.info("[FASHION_SCOUT] Tier-0 (brand-first) query: '%s'", final_query)
            else:
                gemini_query  = data.get("search_query", "").strip()
                gemini_score  = score_query_quality(gemini_query)
                built_query   = self.build_query_from_attributes(data)
                built_score   = score_query_quality(built_query)

                if built_score >= 0.60:
                    final_query = built_query
                    logger.info("[FASHION_SCOUT] Tier-1 (local builder) query: '%s'", final_query)
                elif gemini_score >= 0.40:
                    final_query = gemini_query
                    logger.info("[FASHION_SCOUT] Tier-2 (Gemini direct) query: '%s'", final_query)
                else:
                    top_seo     = " ".join(data.get("seo_keywords", [])[:2])
                    final_query = f"{built_query} {top_seo}".strip() if built_query else top_seo
                    logger.warning("[FASHION_SCOUT] Tier-3 (SEO fallback) query: '%s'", final_query)

            data["search_query"] = final_query   # canonical field — always the chosen query

            # ── Amazon search links ───────────────────────────────────────────
            q_encoded = final_query.replace(" ", "+")
            data["search_links"] = {
                "amazon_us": f"https://www.amazon.com/s?k={q_encoded}" if q_encoded else None,
                "amazon_in": f"https://www.amazon.in/s?k={q_encoded}"  if q_encoded else None,
            }

            # ── Brand-specific direct links (when brand detected) ─────────────
            # These give users a direct path to the exact brand's product results,
            # which is far more conversion-optimised than generic search.
            if _detected_brand and _brand_conf >= 0.7:
                _brand_q = (data.get("brand_search_query") or final_query).replace(" ", "+")
                _brand_encoded = _detected_brand.replace(" ", "+")
                data["brand_store_links"] = {
                    "amazon_in_brand": (
                        f"https://www.amazon.in/s?k={_brand_q}"
                        f"&rh=p_89%3A{_brand_encoded}"
                    ),
                    "amazon_us_brand": (
                        f"https://www.amazon.com/s?k={_brand_q}"
                        f"&rh=p_89%3A{_brand_encoded}"
                    ),
                    "myntra_brand": (
                        f"https://www.myntra.com/{_detected_brand.lower().replace(' ', '-')}"
                    ),
                    "flipkart_search": (
                        f"https://www.flipkart.com/search?q={_brand_q}"
                    ),
                }
                logger.info(
                    "🔗 [BRAND_LINKS] Brand store links generated for '%s'",
                    _detected_brand,
                )


            # ── SEO keyword pass-through + clickable bindings ─────────────────
            seo_kws: List[str] = data.get("seo_keywords", [])
            data["seo_search_keywords"] = seo_kws
            data["seo_binded_links"] = [
                {
                    "kw":      kw,
                    "link_in": f"https://www.amazon.in/s?k={kw.replace(' ', '+').replace(chr(34), '')}",
                    "link_us": f"https://www.amazon.com/s?k={kw.replace(' ', '+').replace(chr(34), '')}",
                }
                for kw in seo_kws[:3]
            ]

            logger.info(
                "✅ Fashion Scout complete — "
                "anchor='%s' | category='%s' | vibe='%s' | score=%.3f",
                data.get("visual_dominance", {}).get("primary_garment_id", "?"),
                item_category,
                data.get("vibe", "?"),
                data.get("_internal_score", 0.0),
            )
            return data

        except Exception as exc:
            logger.error("❌ Fashion Scout fatal error: %s", exc, exc_info=True)
            return None


# ─────────────────────────────────────────────────────────────────────────────
# MODULE SINGLETON
# ─────────────────────────────────────────────────────────────────────────────
scout = FashionScout()


# ─────────────────────────────────────────────────────────────────────────────
# UTILITIES & LEGACY SHIMS
# ─────────────────────────────────────────────────────────────────────────────

def get_fallback_payload() -> Dict[str, Any]:
    """
    Returns a safe, neutral fallback payload used when Gemini fails 
    or confidence is unrecoverably low.
    """
    return {
        "visual_dominance": {
            "primary_garment_id": "apparel",
            "dominance_score": 5,
            "frame_coverage_pct": 30,
            "dominance_reason": "Fallback due to detection failure",
            "secondary_garments": [],
            "ignored_items": []
        },
        "attributes": {
            "classification": {"primary_category": "apparel", "sub_category": "casual wear"}
        },
        "outfit_description": "Standard fashion apparel",
        "search_query": "casual comfortable wear",
        "seo_keywords": ["fashion", "apparel", "clothing"],
        "confidence": {"detection": 0.0, "query": 0.0, "overall": 0.0},
        "vibe": "CASUAL",
        "fashion": { # Legacy compatibility shim
            "vibe": "CASUAL",
            "outfit_description": "Standard fashion apparel",
            "search_queries": {"amazon": "casual comfortable wear", "general": "casual outfit"}
        }
    }