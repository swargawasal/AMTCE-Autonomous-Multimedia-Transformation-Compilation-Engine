# =============================================================
# AMTCE — Environment Variable Template
# Copy this file to Credentials/.env and fill in your values.
# NEVER commit the actual .env file to source control.
# =============================================================

# ==================== CORE SETTINGS ====================
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_GROUP_ID=@your_telegram_group

# ==================== AI PROVIDERS ====================
# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash-lite

# Groq (ultra-fast captions) — https://console.groq.com
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT=3

# Mistral (narrative / reasoning) — https://console.mistral.ai
MISTRAL_API_KEY=YOUR_MISTRAL_API_KEY_HERE
MISTRAL_MODEL=mistral-large-latest
MISTRAL_TIMEOUT=25

# DeepSeek (optional backup reasoner)
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY_HERE
DEEPSEEK_MODEL=deepseek-chat

# Cerebras (optional high-throughput batch)
CEREBRAS_API_KEY=YOUR_CEREBRAS_API_KEY_HERE
CEREBRAS_MODEL=llama-3.3-70b
CEREBRAS_TIMEOUT=15

# ==================== BRANDING ====================
BRAND_NAME=@your_brand_handle
IG_OWNER_NAME=your_instagram_handle
IG_OWNER_BIO=Your brand description here.

# ==================== META (Instagram / Facebook) ====================
ENABLE_META_UPLOAD=no
META_PAGE_ID=YOUR_META_PAGE_ID
META_PAGE_TOKEN=YOUR_META_PAGE_ACCESS_TOKEN
IG_BUSINESS_ID=YOUR_IG_BUSINESS_ACCOUNT_ID
IG_BUSINESS_TOKEN=YOUR_IG_ACCESS_TOKEN
SEND_TO_INSTAGRAM=off
SEND_TO_FACEBOOK=off

# ==================== YOUTUBE OAUTH ====================
SEND_TO_YOUTUBE=off
CLIENT_SECRET_FILE=Credentials/client_secret.json
YOUTUBE_TOKEN_FILE=Credentials/token.json

# ==================== SMTP (Optional — B2B lead capture) ====================
SMTP_USER=your@email.com
SMTP_PASS=YOUR_APP_PASSWORD_HERE

# ==================== LANGFUSE OBSERVABILITY (Optional) ====================
LANGFUSE_SECRET_KEY=YOUR_LANGFUSE_SECRET_KEY
LANGFUSE_PUBLIC_KEY=YOUR_LANGFUSE_PUBLIC_KEY
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ==================== PERFORMANCE ====================
CPU_MODE=on
GPU_MODE=off
REENCODE_PRESET=fast
REENCODE_CRF=18
RENDER_TARGET=quality

# ==================== ENHANCEMENT ====================
ENHANCEMENT_LEVEL=medium
PRO_SKIN_STABILITY=yes
TARGET_RESOLUTION=1080:1920

# ==================== TEXT OVERLAY ====================
ADD_TEXT_OVERLAY=yes
TEXT_OVERLAY_CONTENT=YOUR_BRAND_HANDLE
TEXT_OVERLAY_POSITION=bottom
TEXT_OVERLAY_SIZE=60

# ==================== WATERMARK ====================
ENABLE_WATERMARK_REMOVAL=yes
ENABLE_WATERMARK_REPLACEMENT=yes
WATERMARK_REPLACE_PATH=assets/watermark.png
MY_WATERMARK_TEXT=YOUR_BRAND_HANDLE
WATERMARK_ENGINE_PRESET=balanced

# ==================== AUDIO ====================
ENABLE_HEAVY_REMIX_SHORTS=yes
ENABLE_HEAVY_REMIX_COMPILATION=yes
MUSIC_SELECTION_MODE=beat_match
BGM_DIR=music
MUSIC_VOLUME=0.4
ORIGINAL_AUDIO_VOLUME=1.0
FORCE_AUDIO_REMIX=yes

# ==================== COMPILATION ====================
COMPILATION_BATCH_SIZE=20
DEFAULT_HASHTAGS_SHORTS="#shorts #viral #trending"
DEFAULT_HASHTAGS_COMPILATION="#compilation #funny #viral"
ENABLE_COMPILATION_INTRO=yes

# ==================== FEATURE FLAGS ====================
ENABLE_META_UPLOAD=no
ENABLE_INFLUENCER_REFINEMENT=no
ENABLE_REACTION_ENGINE=no
ENABLE_LIP_SYNC=no
ENABLE_FACE_SWAP=no
ENABLE_FASHION_SCOUT=yes
ENABLE_AI_IMAGE_CREATION=false
ENABLE_AI_VIDEO_CREATION=false
LOS_POLLOS_YOUTUBE=no
LOS_POLLOS_TELEGRAM=no
DM_AUTO_RESPONDER_ENABLED=no
